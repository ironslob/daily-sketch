// Shared build settings for all configurations.
IPHONEOS_DEPLOYMENT_TARGET = 18.0
SWIFT_VERSION = 6.0
MARKETING_VERSION = 0.1.0
CURRENT_PROJECT_VERSION = 1

// Owner must supply Apple Developer Team ID before signed device/TestFlight builds.
// DEVELOPMENT_TEAM =

SUPPORT_URL = https:/$()/example.com/daily-sketch/support
PRIVACY_URL = https:/$()/example.com/daily-sketch/privacy
TERMS_URL = https:/$()/example.com/daily-sketch/terms
COMMUNITY_GUIDELINES_URL = https:/$()/example.com/daily-sketch/community-guidelines
SENTRY_DSN =
ANALYTICS_ENVIRONMENT = local
LOGGING_LEVEL = debug
SHOW_ENVIRONMENT_BADGE = YES
