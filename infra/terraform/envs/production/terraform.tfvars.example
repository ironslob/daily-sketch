aws_region                = "eu-west-1"
vpc_cidr                  = "10.30.0.0/16"
media_bucket_name         = "dailysketch-production-media-ACCOUNT_ID"  # pragma: allowlist secret
api_domain_name           = "api.example.com"
api_acm_certificate_arn   = "arn:aws:acm:eu-west-1:ACCOUNT_ID:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # pragma: allowlist secret
cdn_domain_name           = "media.example.com"
cdn_acm_certificate_arn   = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # pragma: allowlist secret

backend_image             = "ACCOUNT_ID.dkr.ecr.eu-west-1.amazonaws.com/dailysketch-backend:production"
backend_desired_count     = 2
backend_cpu               = 1024
backend_memory            = 2048
db_instance_class         = "db.t4g.small"
db_allocated_storage_gb   = 50
db_max_allocated_storage_gb = 200
db_backup_retention_days  = 14
release_version           = "1.0.0"
commit_sha                = "unknown"
build_timestamp           = "unknown"
descope_project_id        = "Pxxxxxxxxxxxxxxxxxxxxxx"
descope_issuer              = "https://api.descope.com/v1/apps/Pxxxxxxxxxxxxxxxxxxxxxx"
descope_audience            = "production-audience"

# Required in production — copy to terraform.tfvars locally; never commit.
# moderation_operator_token = "..."
# sentry_dsn                = "..."
# alert_webhook_url         = "..."
# alarm_sns_topic_arn       = "arn:aws:sns:eu-west-1:ACCOUNT_ID:ops-alerts"
