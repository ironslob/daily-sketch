# Application
APP_ENV=local
LOG_LEVEL=INFO
API_PUBLIC_URL=http://localhost:8000
RELEASE_VERSION=0.1.0
COMMIT_SHA=unknown
REQUEST_TIMEOUT_SECONDS=30
PROMPT_DATE_TIMEZONE=UTC
SKETCH_SESSION_EXPIRY_SECONDS=86400

# Database (local Docker Compose)
DATABASE_URL=postgresql+asyncpg://dailysketch:dailysketch@localhost:5432/dailysketch

# Object storage (local MinIO)
STORAGE_ENDPOINT=http://localhost:9000
# Host-reachable endpoint for signed URLs handed to iOS (defaults to STORAGE_ENDPOINT).
# When the backend runs in Docker and talks to MinIO as http://minio:9000, set:
# STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=dailysketch-local-media
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false

# Upload and image limits
ALLOWED_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/webp
MAX_UPLOAD_BYTES=10485760
SIGNED_UPLOAD_EXPIRY_SECONDS=900
SIGNED_READ_EXPIRY_SECONDS=3600
CAPTION_MAX_LENGTH=280
REFLECTION_MAX_LENGTH=500

# Descope (placeholders — replace with development project values)
DESCOPE_PROJECT_ID=replace-me
DESCOPE_ISSUER=https://api.descope.com/v1/apps/replace-me
DESCOPE_AUDIENCE=replace-me
# Optional override; defaults to https://api.descope.com/{DESCOPE_PROJECT_ID}/.well-known/jwks.json
# DESCOPE_JWKS_URL=

# Internal moderation operator secret (Phase 11). Required for /internal/moderation/* only.
# Leave empty locally to deny all operator calls. Never reuse production values.
MODERATION_OPERATOR_TOKEN=

# MinIO root credentials used by Docker Compose only
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Postgres used by Docker Compose only
POSTGRES_USER=dailysketch
POSTGRES_PASSWORD=dailysketch
POSTGRES_DB=dailysketch
